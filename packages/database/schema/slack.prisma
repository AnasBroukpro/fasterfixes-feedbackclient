// Slack notification integration: org-level installation, per-project channel
// link, and per-feedback message reference enabling in-place message edits.

model SlackInstallation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  slackTeamId   String @unique
  slackTeamName String

  botToken  String // encrypted at rest (AES-256-GCM)
  botUserId String
  scope     String?

  installedById String?
  installedBy   Member? @relation(fields: [installedById], references: [id], onDelete: SetNull)

  projectLinks ProjectSlackLink[]

  @@index([organizationId])
  @@map("slack_installation")
}

model ProjectSlackLink {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  slackInstallationId String
  installation        SlackInstallation @relation(fields: [slackInstallationId], references: [id], onDelete: Cascade)

  channelId   String
  channelName String

  enabled     Boolean @default(true)
  linkHealthy Boolean @default(true)
  healthIssue String?

  feedbackMessages FeedbackSlackMessage[]

  @@index([slackInstallationId])
  @@map("project_slack_link")
}

model FeedbackSlackMessage {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbackId String   @unique
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  projectSlackLinkId String
  projectSlackLink   ProjectSlackLink @relation(fields: [projectSlackLinkId], references: [id], onDelete: Cascade)

  channelId  String
  messageTs  String
  lastSyncAt DateTime?

  @@index([projectSlackLinkId])
  @@map("feedback_slack_message")
}
